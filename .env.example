# Market View Configuration

# Server
PORT=3000

# Database
DATABASE_PATH=./data/market-view.db

# HX Rate Checker (requires VPN)
HX_RATE_CHECKER_URL=https://rate-checker.internalapps.holidayextras.com/#/galaxyConnect/getProducts?isTestEnvironment=false&supplierId=abe869be-e545-4e59-ab86-211e4f776642

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
EMAIL_TO=andy@example.com
EMAIL_FROM=marketview@example.com

# Booking.com proxy (ScraperAPI free tier: 5000 requests)
# Sign up at https://www.scraperapi.com/ and paste your API key
SCRAPERAPI_KEY=

# Scheduler
CRON_SCHEDULE=0 8 * * *
TZ=Europe/London
